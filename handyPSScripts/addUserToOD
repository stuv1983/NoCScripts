# Connect to SharePoint Online Admin Center
Connect-SPOService -Url https://contoso-admin.sharepoint.com/

# Grant Site Collection Admin rights to both users on the target OneDrive site
Set-SPOUser -Site https://contoso-my.sharepoint.com/personal/j_smith_contoso_com -LoginName a.jones@contoso.com -IsSiteCollectionAdmin $true
Set-SPOUser -Site https://contoso-my.sharepoint.com/personal/j_smith_contoso_com -LoginName b.taylor@contoso.com -IsSiteCollectionAdmin $true

# Verify permissions - returns full list of all users with access to the site
Get-SPOUser -Site https://contoso-my.sharepoint.com/personal/j_smith_contoso_com

# Verify permissions - filtered to only show the two users we just added
Get-SPOUser -Site https://contoso-my.sharepoint.com/personal/j_smith_contoso_com | Where-Object { $_.LoginName -in @("a.jones@contoso.com","b.taylor@contoso.com") }
